<===> tablerow.json
{"arr": [1, 2, 3, 4, 5, 6], "n": 2, "off": 1, "lim": 3}

<===> tablerow.liquid
== cols as a variable ==
{% tablerow i in arr cols: n %}{{ i }}{% endtablerow %}

== cols + limit + offset, all variables ==
{% tablerow i in arr cols: n limit: lim offset: off %}{{ i }}{% endtablerow %}

== mix of literal and variable, comma-separated ==
{% tablerow i in arr cols: 2, limit: lim %}{{ i }}{% endtablerow %}

== string coerces to integer ==
{% tablerow i in arr cols: "3" %}{{ i }}{% endtablerow %}

== variable cols with limit literal ==
{% tablerow i in arr cols:n limit:4 %}{{ i }}{% endtablerow %}
