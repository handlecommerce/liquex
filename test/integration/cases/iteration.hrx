<===> iteration.json
{}

<===> iteration.liquid
{% for i in (1..5) %}
  {{ i }}
  {% if i > 2 %}
    {% break %}
  {% endif %}
  {{ i }}
{% endfor %}

{% for i in (1..5) %}
  {{ i }}
  {% if i > 2 %}
    {% continue %}
  {% endif %}
  {{ i }}
{% endfor %}

{% assign i = 10 %}

{% for i in (1..5) %}
  {{ i }}
  {% if i > 2 %}
    {% continue %}
  {% endif %}
  {{ i }}
{% endfor %}

{{ i }}

== offset:continue and parameter combinations ==
{% assign arr = "1,2,3,4,5,6,7" | split: "," %}
[{% for i in arr limit: 2 %}{{ i }} {% endfor %}]
[{% for i in arr offset: continue %}{{ i }} {% endfor %}]

[{% for i in arr limit: 2 %}{{ i }} {% endfor %}][{% for i in arr limit: 2, offset: continue %}{{ i }} {% endfor %}][{% for i in arr offset: continue %}{{ i }} {% endfor %}]

[{% for i in arr offset: 1 limit: 2 %}{{ i }} {% endfor %}]
[{% for i in arr limit: 2, offset: 1 %}{{ i }} {% endfor %}]